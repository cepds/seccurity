{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "rootDir": "..",
    "outDir": "../dist-electron"
  },
  "include": ["./**/*.ts", "../shared/**/*.ts", "../backend/**/*.ts"]
}
