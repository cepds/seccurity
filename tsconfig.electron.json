{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "rootDir": ".",
    "outDir": "dist-electron"
  },
  "include": ["main.ts", "preload.ts", "electron/**/*.ts", "backend/**/*.ts", "shared/**/*.ts"],
  "exclude": ["dist", "dist-electron", "node_modules"]
}
